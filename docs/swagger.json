{
  "openapi": "3.0.3",
  "info": {
    "title": "LinkPulse API Engine",
    "description": "High-performance URL Shortener and Analytics API engine. Note: Redirection endpoints utilize the Redis Cache-Aside pattern, and click metrics logging events are processed asynchronously through a Go worker pool.",
    "version": "1.0.0"
  },
  "paths": {
    "/r/{code}": {
      "get": {
        "summary": "Redirect Shortened Link",
        "description": "Resolves code using Redis Cache-Aside pattern (singleflight protected). Issues HTTP 302 redirect and fires click events asynchronously using Go worker pools.",
        "parameters": [
          {
            "name": "code",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "302": {
            "description": "Found redirection"
          },
          "404": {
            "description": "Short code not found or deactivated"
          },
          "410": {
            "description": "Short code has expired"
          }
        }
      }
    },
    "/api/v1/links": {
      "post": {
        "summary": "Shorten a URL",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["original_url"],
                "properties": {
                  "original_url": { "type": "string" },
                  "title": { "type": "string" },
                  "custom_alias": { "type": "string" },
                  "expires_at": { "type": "string", "format": "date-time" }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Link created successfully"
          }
        }
      },
      "get": {
        "summary": "List My Links",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 20 } },
          { "name": "search", "in": "query", "schema": { "type": "string" } },
          { "name": "sort", "in": "query", "schema": { "type": "string", "enum": ["created_at", "updated_at", "expires_at"], "default": "created_at" } },
          { "name": "order", "in": "query", "schema": { "type": "string", "enum": ["asc", "desc"], "default": "desc" } }
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/api/v1/analytics/overview": {
      "get": {
        "summary": "Portfolio Analytics Overview",
        "description": "Returns aggregated summary metrics for all links belonging to the authenticated user.",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Overview metrics retrieved successfully"
          }
        }
      }
    },
    "/api/v1/analytics/clicks": {
      "get": {
        "summary": "Time-Series Click History",
        "description": "Returns zero-filled click history timeline counts grouped by time buckets.",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          { "name": "start_date", "in": "query", "schema": { "type": "string", "format": "date-time" } },
          { "name": "end_date", "in": "query", "schema": { "type": "string", "format": "date-time" } },
          { "name": "interval", "in": "query", "schema": { "type": "string", "enum": ["hour", "day", "week", "month"], "default": "day" } }
        ],
        "responses": {
          "200": {
            "description": "Timeline compiled successfully"
          }
        }
      }
    },
    "/api/v1/analytics/top-links": {
      "get": {
        "summary": "Top Performing Links",
        "description": "Returns shortened links ordered by total click counts.",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 10 } }
        ],
        "responses": {
          "200": {
            "description": "Top links retrieved successfully"
          }
        }
      }
    },
    "/api/v1/analytics/devices": {
      "get": {
        "summary": "Device Distribution",
        "description": "Returns device platform percentages and counts (Desktop, Mobile, Tablet, Unknown).",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          { "name": "start_date", "in": "query", "schema": { "type": "string", "format": "date-time" } },
          { "name": "end_date", "in": "query", "schema": { "type": "string", "format": "date-time" } }
        ],
        "responses": {
          "200": {
            "description": "Devices distribution compiled successfully"
          }
        }
      }
    },
    "/api/v1/analytics/browsers": {
      "get": {
        "summary": "Browser Distribution",
        "description": "Returns browser agent counts and percentages (Chrome, Firefox, Safari, Edge, Opera, Unknown).",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          { "name": "start_date", "in": "query", "schema": { "type": "string", "format": "date-time" } },
          { "name": "end_date", "in": "query", "schema": { "type": "string", "format": "date-time" } }
        ],
        "responses": {
          "200": {
            "description": "Browsers distribution compiled successfully"
          }
        }
      }
    },
    "/api/v1/analytics/referrers": {
      "get": {
        "summary": "Referrer Domain Distribution",
        "description": "Returns top domain sources referring click traffic.",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          { "name": "start_date", "in": "query", "schema": { "type": "string", "format": "date-time" } },
          { "name": "end_date", "in": "query", "schema": { "type": "string", "format": "date-time" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 10 } }
        ],
        "responses": {
          "200": {
            "description": "Referrers compiled successfully"
          }
        }
      }
    },
    "/api/v1/links/{id}/analytics": {
      "get": {
        "summary": "Detailed Single Link Analytics",
        "description": "Returns full metrics suite (time-series, devices, browsers, referrers) for a specific shortened link ID.",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } },
          { "name": "start_date", "in": "query", "schema": { "type": "string", "format": "date-time" } },
          { "name": "end_date", "in": "query", "schema": { "type": "string", "format": "date-time" } }
        ],
        "responses": {
          "200": {
            "description": "Link analytics report compiled successfully"
          },
          "404": {
            "description": "Link not found or ownership check failed"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  }
}
